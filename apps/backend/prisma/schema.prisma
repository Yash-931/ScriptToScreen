// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id            String         @id   @default(uuid())
  username      String         @unique()
  name          String
  password      String
  stories       Story[]
  charecters    Charecter[]
}

model Story{
  id            String        @id     @default(uuid())
  title         String
  description   String
  video_url     String
  scenes        Scene[]
  user_id       String
  user          User          @relation(fields: [user_id], references: [id])
  charecters    Story_Charecters[]
}

model Scene{
  id            String         @id    @default(uuid())
  title         String 
  description   String
  image_url     String
  story_id      String
  story         Story         @relation(fields: [story_id],references: [id])
}

model Charecter{
  id          String             @id      @default(uuid())
  name        String  
  imageUrl    String
  user_id     String?
  user        User?              @relation(fields: [user_id], references: [id])
  stories     Story_Charecters[]
}

model Story_Charecters{
  id            String         @id       @default(uuid())
  story_id      String
  charecter_id  String    
  charecters    Charecter     @relation(fields: [charecter_id], references: [id])
  stories       Story         @relation(fields: [story_id], references: [id])

  @@unique([story_id, charecter_id])
}